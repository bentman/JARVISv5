# App/runtime identity and startup behavior
APP_NAME=JARVISv5
# DEBUG accepts true/false and aliases: dev/debug/development=true, release/prod/production=false
DEBUG=true
HARDWARE_PROFILE=Light
LOG_LEVEL=INFO
# Model fetch policy: never|missing
MODEL_FETCH=never

# Runtime paths
MODEL_PATH=models/
DATA_PATH=data/

# Model escalation controls
ALLOW_MODEL_ESCALATION=false
ESCALATION_PROVIDER=
ESCALATION_BUDGET_USD=0.0

# Ollama host escalation (local host inference)
# OLLAMA_BASE_URL uses host.docker.internal to reach host from inside the container.
# On Linux with Docker Engine, ensure extra_hosts is set in docker-compose.yml.
# Do not point OLLAMA_BASE_URL at a remote host; redaction is not applied on this path.
ALLOW_OLLAMA_ESCALATION=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3:mini

# Provider API keys
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=

# Search controls and providers
ALLOW_EXTERNAL_SEARCH=true
DEFAULT_SEARCH_PROVIDER=searxng
ALLOW_PAID_SEARCH=false
SEARCH_SEARXNG_URL=http://searxng:8080/search
TAVILY_API_KEY=

# Cache and TTL controls
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL=3600
CONTEXT_CACHE_TTL_SECONDS=3600
TOOL_CACHE_TTL_SECONDS=1800
