# [app/runtime]
APP_NAME=JARVISv5
DEBUG=true
HARDWARE_PROFILE=Light
LOG_LEVEL=INFO

# [privacy/redaction]
REDACT_PII_QUERIES=true
REDACT_PII_RESULTS=false

# [paths]
MODEL_PATH=models/
DATA_PATH=data/

# [model/runtime behavior]
MODEL_FETCH=never

# [escalation]
ALLOW_MODEL_ESCALATION=false
ESCALATION_PROVIDER=
ESCALATION_BUDGET_USD=0.0

# [ollama]
# host.docker.internal is used for container->host access.
ALLOW_OLLAMA_ESCALATION=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3:mini

# [provider keys]
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=

# [search]
ALLOW_EXTERNAL_SEARCH=true
DEFAULT_SEARCH_PROVIDER=searxng
ALLOW_PAID_SEARCH=false
SEARCH_SEARXNG_URL=http://searxng:8080/search
TAVILY_API_KEY=

# [cache]
CACHE_ENABLED=true
REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TTL=3600
CONTEXT_CACHE_TTL_SECONDS=3600
TOOL_CACHE_TTL_SECONDS=1800
