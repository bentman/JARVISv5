# [app/runtime]
# Core app runtime identity, logging, and model fetch behavior.
APP_NAME=JARVISv5
DEBUG=true
HARDWARE_PROFILE=Light
LOG_LEVEL=INFO
MODEL_FETCH=never

# [paths]
# Filesystem roots for model assets and runtime data.
MODEL_PATH=models/
DATA_PATH=data/

# [planning/retrieval]
# Retrieval scoring and planning context limits used at runtime.
RETRIEVAL_MAX_RESULTS=10
RETRIEVAL_MIN_SCORE=0.0
RETRIEVAL_TIME_DECAY_TAU_HOURS=24.0

# [privacy/redaction]
# Query/result PII redaction toggles for runtime processing.
REDACT_PII_QUERIES=true
REDACT_PII_RESULTS=false

# [search]
# External search provider selection and search/retrieval controls.
ALLOW_EXTERNAL_SEARCH=true
DEFAULT_SEARCH_PROVIDER=searxng
ALLOW_PAID_SEARCH=false
SEARCH_SEARXNG_URL=http://searxng:8080/search
TAVILY_API_KEY=

# [cache]
# Redis and TTL settings for context/tool caching behavior.
CACHE_ENABLED=true
REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TTL=3600
CONTEXT_CACHE_TTL_SECONDS=3600
TOOL_CACHE_TTL_SECONDS=1800

# [model escalation]
# Cloud escalation policy, provider selection, and budget cap.
ALLOW_MODEL_ESCALATION=false
ESCALATION_PROVIDER=
ESCALATION_BUDGET_USD=0.0

# [ollama]
# Local Ollama escalation endpoint and default model selection.
ALLOW_OLLAMA_ESCALATION=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3:mini

# [provider keys]
# API keys used by external model/search providers.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=
