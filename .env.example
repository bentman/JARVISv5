APP_NAME=JARVISv5
HARDWARE_PROFILE=Light
LOG_LEVEL=INFO

# DEBUG accepts true/false and aliases: dev/debug/development=true, release/prod/production=false
DEBUG=true

# Runtime paths (used by API/controller)
MODEL_PATH=models/
DATA_PATH=data/

# Model fetch policy: never|missing
MODEL_FETCH=never

# Search provider live execution (SearXNG)
ALLOW_PAID_SEARCH=false
SEARCH_SEARXNG_URL=http://searxng:8080/search
TAVILY_API_KEY=

# API Keys and External Services
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=

# Model escalation settings
ALLOW_MODEL_ESCALATION=false
ESCALATION_PROVIDER=
ESCALATION_BUDGET_USD=0.0

# Cache settings
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL=3600

# Context cache TTL in seconds
CONTEXT_CACHE_TTL_SECONDS=3600

# Tool cache TTL in seconds
TOOL_CACHE_TTL_SECONDS=1800
